{{ end }}
{{- else }}
✅ <b>[RESOLVED] {{ .CommonLabels.alertname }}</b>{{ if .CommonAnnotations.summary }} — {{ .CommonAnnotations.summary }}{{ end }}
{{ range .Alerts }}
<b>主機：</b>{{ if .Labels.hostname }}{{ .Labels.hostname }} ({{ .Labels.instance }}){{ else }}{{ .Labels.instance }}{{ end }}
<b>類型：</b>{{ if .Labels.role }}{{ .Labels.role }}{{ else }}—{{ end }}
<b>環境：</b>{{ if .Labels.env }}{{ .Labels.env }}{{ else }}—{{ end }}
<b>恢復時間：</b>{{ .EndsAt.Local.Format "2006-01-02 15:04:05" }}
