# Generated by Ansible — do not edit manually
# Source: inventory/hosts.yml

{% if ssh_config_global %}
Host *
{% for key, value in ssh_config_global.items() %}
  {{ key }} {{ value }}
{% endfor %}

{% endif %}
{% for host in groups['all'] | sort %}
{% set h = hostvars[host] %}
Host {{ host }}
  HostName {{ h.ansible_host }}
  User {{ h.ansible_user | default('root') }}
{% if h.ansible_ssh_private_key_file is defined %}
{% if h.ansible_ssh_private_key_file != '' %}
  IdentityFile {{ h.ansible_ssh_private_key_file }}
{% endif %}
{% else %}
  IdentityFile {{ ssh_config_default_identity }}
{% endif %}
{% if not ssh_config_strict_host_checking %}
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
{% endif %}

{% endfor %}
